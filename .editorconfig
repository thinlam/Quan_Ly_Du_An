# Top-level EditorConfig file: https://EditorConfig.org
root = true

##########################################
# All files
##########################################
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

##########################################
# C# files
##########################################
[*.cs]
indent_size = 4

# === Brace style: { cung dong method/control (K&R / Java style) ===
csharp_new_line_before_open_brace = false

# else/catch/finally cung dong voi` block truoc do
csharp_new_line_before_else = false
csharp_new_line_before_catch = false
csharp_new_line_before_finally = false

# Lambda body, object initializer, anonymous type
csharp_new_line_before_members_in_object_initializers = false
csharp_new_line_before_members_in_anonymous_types = false

# LINQ query
csharp_new_line_between_query_expression_clauses = false

# === Using directives ===
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false

# === var ===
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = true:suggestion

# === this. chi khi can thiet ===
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_property = false:suggestion
dotnet_style_qualification_for_method = false:suggestion
dotnet_style_qualification_for_event = false:suggestion

# === Predefined types ===
dotnet_style_predefined_type_for_locals_parameters_members = true:warning
dotnet_style_predefined_type_for_member_access = true:warning

# === Expression-bodied members ===
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = true:suggestion
csharp_style_expression_bodied_accessors = true:suggestion
csharp_style_expression_bodied_lambdas = true:suggestion
csharp_style_expression_bodied_local_functions = when_on_single_line:suggestion

# === Pattern matching ===
csharp_style_pattern_matching_over_is_with_cast_check = true:warning
csharp_style_pattern_matching_over_as_with_null_check = true:warning

# === Throwing & using ===
csharp_style_throw_expression = true:suggestion
csharp_style_using_simple_using_statement = true:suggestion

##########################################
# JSON / XML / YAML
##########################################
[*.{json,xml,yml,yaml}]
indent_size = 2

##########################################
# Markdown
##########################################
[*.md]
trim_trailing_whitespace = false
